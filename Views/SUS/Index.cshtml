@model BurnoutSurveyMVC.ViewModels.SUSViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<h2 class="h4 mb-3">Avaliação de Usabilidade (SUS)</h2>
<p class="text-muted">Para cada afirmação, marque de 1 (Discordo totalmente) a 5 (Concordo totalmente).</p>

<form method="post"> @Html.AntiForgeryToken()  @Html.ValidationSummary(true, null, new { @class = "text-danger" })
  <input type="hidden" name="ParticipanteId" value="@Model.ParticipanteId" />
  <div class="vstack gap-3">
    @for (int i = 0; i < Model.Itens.Count; i++)
    {
        var it = Model.Itens[i];
        <div class="border rounded p-3 bg-white">
          <div class="fw-semibold mb-2">@it.Numero. @it.Texto</div>
          <div class="d-flex flex-wrap gap-3">
            @for (int v = 1; v <= 5; v++)
            {
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="Itens[@i].Valor" value="@v" required />
                    <label class="form-check-label">@v</label>
                </div>
            }
          </div>
          <input type="hidden" name="Itens[@i].Numero" value="@it.Numero" />
          <input type="hidden" name="Itens[@i].Texto" value="@it.Texto" />
        </div>
    }
  </div>
  <div class="mt-3 d-flex justify-content-between">
    <a class="btn btn-outline-secondary" href="/MBI">Voltar</a>
    <button class="btn btn-primary" type="submit">Concluir e ver resultado</button>
  </div>
</form>
