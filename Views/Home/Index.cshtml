@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background: url('image/coffee.jpg') center center fixed;
        background-size: cover;
    }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            z-index: -1;
        }

    .container{
        margin-left: 50px !important;
    }

    @@media (max-width: 992px) {
        .container {
            margin-left: 0 !important;
            margin-right: 0 !important;
            padding-left: 1rem;
            padding-right: 1rem;
        }
    }
</style>

<body>
    <main id="mainForm" class="d-flex justify-content-center align-items-center" style="min-height: calc(100vh - 200px);">
        <div class="text-center text-white p-5 rounded shadow" style="max-width: 600px; background-color:#212429; opacity: 90%">
            <h1 class="mb-3">Burnout Devs</h1>
            <p class="text-start">
                Uma pesquisa acadêmica anônima sobre o bem-estar emocional de profissionais de tecnologia.
            </p>
            <a class="btn btn-light btn-lg" style="font-weight:700" href="/Consent">Participar da pesquisa</a>
        </div>
    </main>
</body>