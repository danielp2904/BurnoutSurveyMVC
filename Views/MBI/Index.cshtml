@model BurnoutSurveyMVC.ViewModels.MBIViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="h4 mb-3">Questionário</h2>
<p class="text-muted">Responda de 0 (Nunca) a 6 (Todos os dias).</p>

<form id="mbiForm" method="post">
  @Html.AntiForgeryToken()
  @Html.ValidationSummary(true, null, new { @class = "text-danger" })
  <input type="hidden" name="ParticipanteId" value="@Model.ParticipanteId" />

  <!-- Indicador simples de progresso -->
  <div class="progress mb-3" aria-hidden="true">
    <div id="mbiProgress" class="progress-bar" style="width:0%"></div>
  </div>

  <!-- Grupos em sequência (cada um abre quando o anterior estiver completo) -->
  <div class="vstack gap-4">
  @for (int gi = 0; gi < Model.Grupos.Count; gi++)
  {
      var g = Model.Grupos[gi];
      var isFirst = gi == 0;
      <section class="mbi-group @(isFirst ? "" : "d-none")" data-index="@gi">
        <h5 class="mb-2">@g.Titulo</h5>
        @if (!string.IsNullOrWhiteSpace(g.Explicacao)) {
          <div class="alert alert-info">@g.Explicacao</div>
        }

        <div class="vstack gap-3">
          @for (int i = 0; i < g.Itens.Count; i++)
          {
              var it = g.Itens[i];
              <div class="border rounded p-3">
                <div class="fw-semibold mb-2">@it.Codigo — @it.Texto</div>
                <div class="d-flex flex-wrap gap-2">
                  @for (int v = 0; v <= 6; v++)
                  {
                      var req = isFirst ? "required" : null;
                      <div class="form-check form-check-inline">
                        <input class="form-check-input"
                               type="radio"
                               name="Grupos[@gi].Itens[@i].Valor"
                               value="@v"
                               @(req != null ? "required" : "")
                               data-question="Grupos[@gi].Itens[@i].Valor" />
                        <label class="form-check-label">@v</label>
                      </div>
                  }
                </div>

                <input type="hidden" name="Grupos[@gi].Itens[@i].QuestionId" value="@it.QuestionId" />
                <input type="hidden" name="Grupos[@gi].Itens[@i].Codigo" value="@it.Codigo" />
                <input type="hidden" name="Grupos[@gi].Itens[@i].Texto" value="@it.Texto" />
              </div>
          }
        </div>
      </section>
  }
  </div>

  <div class="mt-3 d-flex justify-content-between">
    <a class="btn btn-outline-secondary" href="/Consent">Voltar</a>
    <button class="btn btn-primary" type="submit">Prosseguir para avaliação do site</button>
  </div>
</form>

<!-- Script movido para fora da seção para evitar erro no Layout -->
<script defer>
(function () {
  const form = document.getElementById('mbiForm');
  if (!form) return;

  const groups = Array.from(form.querySelectorAll('.mbi-group'));
  const progressBar = document.getElementById('mbiProgress');

  // ao carregar: garante required só no grupo visível
  groups.forEach((g, idx) => toggleRequired(g, idx === 0));
  updateProgress();

  form.addEventListener('change', function (e) {
    const group = e.target.closest('.mbi-group');
    if (!group) return;

    if (groupComplete(group)) {
      const next = nextGroup(group);
      if (next && next.classList.contains('d-none')) {
        next.classList.remove('d-none');
        toggleRequired(next, true); // ativa required quando abrir
        const firstRadio = next.querySelector('input[type=radio]');
        if (firstRadio) firstRadio.focus({ preventScroll: true });
        next.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
    updateProgress();
  });

  // bloqueia submit se houver grupo visível não completo
  form.addEventListener('submit', function (e) {
    for (const g of groups) {
      if (g.classList.contains('d-none')) break; // só checamos os já abertos
      if (!groupComplete(g)) {
        g.scrollIntoView({ behavior: 'smooth', block: 'start' });
        e.preventDefault();
        return;
      }
    }
  });

  function groupComplete(groupEl) {
    const names = new Set(Array.from(groupEl.querySelectorAll('input[type=radio]'))
      .map(r => r.getAttribute('data-question')));
    for (const name of names) {
      if (!groupEl.querySelector('input[type=radio][data-question="' + name + '"]:checked')) {
        return false;
      }
    }
    return true;
  }

  function nextGroup(groupEl) {
    const idx = parseInt(groupEl.getAttribute('data-index'));
    return groups[idx + 1] || null;
  }

  function toggleRequired(groupEl, on) {
    groupEl.querySelectorAll('input[type=radio]').forEach(r => {
      if (on) r.setAttribute('required', 'required');
      else r.removeAttribute('required');
    });
  }

  function updateProgress() {
    const done = groups.filter(g => !g.classList.contains('d-none') && groupComplete(g)).length;
    const pct = Math.round((done / groups.length) * 100);
    if (progressBar) {
      progressBar.style.width = pct + '%';
      progressBar.setAttribute('aria-valuenow', pct);
    }
  }
})();
</script>
